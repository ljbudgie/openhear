  (title_block
    (title "OpenHear Aids-Free Wristband v1 Reference Schematic")
    (date "2026-05-01")
    (rev "v1-diy")
    (company "OpenHear")
    (comment 1 "CERN-OHL-S-2.0; Burgess Principle local-only data path")
    (comment 2 "ESP32-S3/RP2040, DRV2605L LRA drivers, 8 MEMS mics, IMU, Li-Po power")
  )
  (text "Functional blocks: U1 ESP32-S3-MINI-1 or RP2040+nRF52840; U2 BQ24075 charger/power-path; U3 TPS62743 3V3 buck; U4 BMI270/BNO055 IMU; U5-U12 SPH0645LM4H MEMS mics; U20-U35 DRV2605L haptic drivers on TCA9548A I2C muxes; J1 flex actuator bus; J2 v0 micro:bit shim UART/PWM; J3 USB-C debug/charge; J4 Qi receiver pads." (at 25.4 25.4 0)
    (effects (font (size 2.0 2.0)) (justify left bottom))
    (uuid "4b63ab7b-5c1b-43a1-a64f-0a0dd07b7ff9")
  )
  (text "Latency path: PDM DMA ring -> 0.5 ms filterbank window -> audiogram LUT -> haptic DMA scheduler -> I2C/SPI driver update. BLE is companion-only and never required for hearing." (at 25.4 38.1 0)
    (effects (font (size 1.6 1.6)) (justify left bottom))
    (uuid "93be0eec-f299-4a87-a1e5-ef743f72b056")
  )
  (text "Route as four rigid islands plus flex tails. Keep MEMS ports clear of silicone. Star-route motor returns; isolate PDM clocks from LRA current pulses." (at 25.4 50.8 0)
    (effects (font (size 1.6 1.6)) (justify left bottom))
    (uuid "c049f1cf-2e9b-430a-a60d-eb6ec1351701")
  )
  (sheet_instances (path "/" (page "1")))
