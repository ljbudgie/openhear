# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / build
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Runtime outputs
*.json
*.png
*.pdf

# Allow audiogram data files (sovereign data belongs in the repo)
!audiogram/data/*.json
# Allow bundled examples and schemas
!examples/*.json
!dsp/*.schema.json

# IDE / OS
.idea/
.vscode/
*.DS_Store
Thumbs.db

# Test coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
