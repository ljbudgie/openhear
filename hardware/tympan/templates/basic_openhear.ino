// ── Status Reporting ────────────────────────────────────────────────────────
// Prints current status to serial (useful for debugging and monitoring).

void printStatus() {
    Serial.println("--- OpenHear Status ---");
    Serial.print("Uptime: ");
    Serial.print(millis() / 1000);
    Serial.println(" seconds");
    Serial.print("Output: ");
    Serial.println(outputMuted ? "MUTED" : "ACTIVE");
    Serial.print("CPU usage: ");
    Serial.print(AudioProcessorUsage());
    Serial.println("%");
    Serial.print("CPU max: ");
    Serial.print(AudioProcessorUsageMax());
    Serial.println("%");
    Serial.println("-----------------------");
}

// ── SD Card Logging ─────────────────────────────────────────────────────────
// Logs events to the SD card for troubleshooting and calibration records.

void logEvent(const char* eventType, const char* message) {
    if (!SD_LOGGING_ENABLED) return;

    File logFile = SD.open("openhear_log.txt", FILE_WRITE);
    if (logFile) {
        logFile.print(millis());
        logFile.print(",");
        logFile.print(eventType);
        logFile.print(",");
        logFile.println(message);
        logFile.close();
    }
}
