// ── Tympan Library Includes ─────────────────────────────────────────────────
// The Tympan Library provides all the DSP building blocks: audio I/O,
// filters, compression, noise reduction, and Bluetooth control.

#include <Tympan_Library.h>

// ── Hardware Configuration ──────────────────────────────────────────────────
// TympanRev::F = Tympan Rev F board (current production model).
// SAMPLE_RATE_HZ: 24000 Hz is a good balance between audio quality and
// processing headroom.  The Tympan supports up to 96000 Hz.
// AUDIO_BLOCK_SAMPLES: Number of samples processed per DSP cycle.  Smaller
// blocks = lower latency but higher CPU overhead.  128 gives ~5ms blocks
// at 24 kHz, well within the Tympan's processing budget.

Tympan myTympan(TympanRev::F);
const float SAMPLE_RATE_HZ = 24000.0f;
const int AUDIO_BLOCK_SAMPLES = 128;

// ── 8-Band WDRC Configuration ──────────────────────────────────────────────
// WDRC = Wide Dynamic Range Compression.  This is the core hearing aid
// algorithm.  It divides audio into 8 frequency bands and applies
// independent compression to each band.
//
// How it works:
//   - Sounds below the "knee point" are amplified by the full gain amount
//   - Sounds above the knee point are compressed: a loud sound is made
//     quieter relative to what it would be without compression
//   - The compression ratio determines how much compression is applied
//     (2:1 means a 20 dB increase in input produces only 10 dB increase
//     in output)
//   - Attack time: how quickly compression engages when sound gets loud
//   - Release time: how quickly compression releases when sound gets quiet
//
// These values are computed from your audiogram by audiogram_to_tympan.py.
// Each array has 8 elements, one per frequency band.

// Number of frequency bands for WDRC processing
const int N_CHAN = {{N_CHAN}};

// Centre frequencies of each band (Hz).
// These divide the audio spectrum into 8 bands for independent processing.
// The bands are spaced to match standard audiometric frequencies.
float cross_freq_hz[N_CHAN - 1] = {{CROSSOVER_FREQUENCIES}};

// Per-band gain in dB.  This is how much each frequency band is amplified.
// Higher numbers = more amplification.  Computed from your audiogram:
// gain = max(0, your_threshold - 20 dB).  A threshold of 60 dB at 2 kHz
// means 40 dB of gain at that frequency.
float gain_db[N_CHAN] = {{GAIN_DB}};

// Compression ratio per band.  Determines how much loud sounds are
// "squashed".  1.0 = no compression (linear).  2.0 = 2:1 compression
// (20 dB input increase → 10 dB output increase).  Higher ratios for
// bands with more hearing loss.
float comp_ratio[N_CHAN] = {{COMPRESSION_RATIOS}};

// Compression knee point in dB SPL.  Sounds below this level get full
// gain.  Sounds above this level are compressed.  Lower knee = compression
// starts at quieter sounds (appropriate for more hearing loss).
float knee_dbspl[N_CHAN] = {{KNEE_DBSPL}};

// Maximum Power Output per band in dB SPL.  The absolute loudest the
// software will allow each band to produce.  Set from your estimated
// Uncomfortable Loudness Level (UCL) minus a safety margin.
// THE HARDWARE MPO LIMITER IS THE FINAL SAFETY LAYER — these software
// limits are defence in depth.
float mpo_dbspl[N_CHAN] = {{MPO_DBSPL}};

// Attack time in milliseconds.  How quickly compression engages when
// sound suddenly gets loud.  5 ms is fast — preserves the "snap" of
// consonants and transient sounds for speech clarity.
float attack_ms[N_CHAN] = {{ATTACK_MS}};

// Release time in milliseconds.  How quickly compression releases when
// sound gets quiet again.  200 ms is slow — prevents "pumping" artifacts
// where the volume noticeably fluctuates.
float release_ms[N_CHAN] = {{RELEASE_MS}};

// ── Noise Reduction Configuration ───────────────────────────────────────────
// Noise reduction suppresses steady-state background noise (fans, traffic,
// hum) while preserving speech.  It works by estimating the noise floor
// in each frequency band and subtracting it from the signal.
//
// aggressiveness: 0.0 = off, 1.0 = mild, 2.0 = moderate, 3.0 = aggressive
// Higher values remove more noise but may also remove quiet speech.

const bool NOISE_REDUCTION_ENABLED = {{NOISE_REDUCTION_ENABLED}};
const float NOISE_REDUCTION_AGGRESSIVENESS = {{NOISE_REDUCTION_LEVEL}};

// ── Feedback Cancellation ───────────────────────────────────────────────────
// Feedback = the high-pitched whistle when amplified sound leaks from the
// ear canal back to the microphone, creating a loop.  The adaptive feedback
// canceller identifies the feedback path and subtracts it from the signal.
//
// This should always be enabled when using in-ear receivers.

const bool FEEDBACK_CANCELLATION_ENABLED = {{FEEDBACK_CANCELLATION_ENABLED}};

// ── Safety Parameters ───────────────────────────────────────────────────────
// Software safety limits.  These are DEFENCE IN DEPTH — the hardware MPO
// limiter is the primary safety mechanism and cannot be overridden here.

// Maximum gain ceiling per band (dB).  Even if the audiogram calls for
// more gain, the software will not exceed these values.
float max_gain_ceiling_db[N_CHAN] = {{MAX_GAIN_CEILING}};

// Watchdog timeout in milliseconds.  If the DSP processing loop does not
// complete within this time, the watchdog triggers and mutes output.
// 10 ms = ~2.4 audio blocks at 24 kHz sample rate.
const unsigned long WATCHDOG_TIMEOUT_MS = 10;

// ── Bluetooth Configuration ─────────────────────────────────────────────────
// Bluetooth allows real-time parameter adjustment via the Tympan Remote App.
// The app runs on Android and iOS and connects to the Tympan via BLE.

const bool BLUETOOTH_ENABLED = true;

// ── SD Card Logging ─────────────────────────────────────────────────────────
// Session logging to SD card.  Records configuration, calibration data,
// and usage statistics.

const bool SD_LOGGING_ENABLED = true;

// ── Audio Objects ───────────────────────────────────────────────────────────
// These are the building blocks of the audio processing chain.
// Signal flow: Input → Filter Bank → WDRC (per band) → Sum → Output

AudioInputI2S_F32       audioInput(myTympan);
AudioFilterbankBiquad_F32 filterbank(myTympan, N_CHAN);
AudioEffectCompWDRC_F32 compressor[N_CHAN];
AudioMixer8_F32         mixer(myTympan);
AudioOutputI2S_F32      audioOutput(myTympan);

// Audio connections (defined in setup)
// Input → Filterbank → Compressors → Mixer → Output

// ── Global State ────────────────────────────────────────────────────────────
unsigned long lastDspTime = 0;   // For watchdog timing
bool outputMuted = true;         // Start muted until self-test passes
bool selfTestPassed = false;

// ── Setup ───────────────────────────────────────────────────────────────────

void setup() {
    // Initialise serial for debug output
    Serial.begin(115200);
    delay(500);

    Serial.println("============================================");
    Serial.println("  OpenHear — Starting Up");
    Serial.println("============================================");

    // Initialise the Tympan hardware
    myTympan.enable();
    myTympan.volume(0.0);  // Start silent

    // Set sample rate and block size
    AudioMemory_F32(60, myTympan);

    // Configure input
    myTympan.inputSelect(TYMPAN_INPUT_ON_BOARD_MIC);  // Use on-board mics
    myTympan.setInputGain_dB(15.0);  // Input gain in dB — adjust if clipping

    // ── Configure WDRC per band ─────────────────────────────────────────
    Serial.println("Configuring WDRC...");
    for (int i = 0; i < N_CHAN; i++) {
        compressor[i].setSampleRate_Hz(SAMPLE_RATE_HZ);
        compressor[i].setAttack_msec(attack_ms[i]);
        compressor[i].setRelease_msec(release_ms[i]);
        compressor[i].setGain_dB(gain_db[i]);
        compressor[i].setKneeCompressor_dBSPL(knee_dbspl[i]);
        compressor[i].setCompRatio(comp_ratio[i]);
        compressor[i].setKneeLimiter_dBSPL(mpo_dbspl[i]);

        Serial.print("  Band ");
        Serial.print(i);
        Serial.print(": gain=");
        Serial.print(gain_db[i]);
        Serial.print(" dB, ratio=");
        Serial.print(comp_ratio[i]);
        Serial.print(", MPO=");
        Serial.print(mpo_dbspl[i]);
        Serial.println(" dB SPL");
    }

    // ── Configure filterbank crossover frequencies ──────────────────────
    Serial.println("Configuring filterbank...");
    filterbank.setCrossoverFreqs_Hz(cross_freq_hz, N_CHAN - 1);

    // ── Noise reduction ─────────────────────────────────────────────────
    if (NOISE_REDUCTION_ENABLED) {
        Serial.print("Noise reduction: ON (level ");
        Serial.print(NOISE_REDUCTION_AGGRESSIVENESS);
        Serial.println(")");
    } else {
        Serial.println("Noise reduction: OFF");
    }

    // ── Feedback cancellation ───────────────────────────────────────────
    if (FEEDBACK_CANCELLATION_ENABLED) {
        Serial.println("Feedback cancellation: ON");
    } else {
        Serial.println("Feedback cancellation: OFF");
    }

    // ── Bluetooth ───────────────────────────────────────────────────────
    if (BLUETOOTH_ENABLED) {
        myTympan.setupBLE();
        Serial.println("Bluetooth: ON — connect via Tympan Remote App");
    }

    // ── SD card ─────────────────────────────────────────────────────────
    if (SD_LOGGING_ENABLED) {
        if (myTympan.enableSD()) {
            Serial.println("SD card: ready for logging");
        } else {
            Serial.println("SD card: not detected (logging disabled)");
        }
    }

    // ── Startup self-test ───────────────────────────────────────────────
    Serial.println("Running startup self-test...");
    selfTestPassed = runSelfTest();

    if (selfTestPassed) {
        Serial.println("Self-test: PASSED — enabling audio output");
        outputMuted = false;
        myTympan.volume(0.8);  // Set output volume (0.0 to 1.0)
    } else {
        Serial.println("*** Self-test: FAILED — output remains MUTED ***");
        Serial.println("*** Check connections and review serial output ***");
        outputMuted = true;
        myTympan.volume(0.0);
    }

    Serial.println("============================================");
    Serial.println("  OpenHear — Ready");
    Serial.println("============================================");

    lastDspTime = millis();
}

// ── Main Loop ───────────────────────────────────────────────────────────────

void loop() {
    // ── Watchdog check ──────────────────────────────────────────────────
    // If the DSP loop hasn't completed within WATCHDOG_TIMEOUT_MS, mute
    // output to prevent sustained loud signals.

    unsigned long now = millis();
    if ((now - lastDspTime) > WATCHDOG_TIMEOUT_MS && !outputMuted) {
        // DSP appears stalled — emergency mute
        myTympan.volume(0.0);
        outputMuted = true;
        Serial.println("*** WATCHDOG: DSP stall detected — output MUTED ***");

        if (SD_LOGGING_ENABLED) {
            logEvent("WATCHDOG_MUTE", "DSP stall detected");
        }
    }

    // ── Normal DSP processing ───────────────────────────────────────────
    // The actual audio processing is handled by the Tympan audio library
    // in the background (interrupt-driven).  The loop() function handles
    // supervisory tasks: watchdog, Bluetooth commands, logging.

    lastDspTime = millis();

    // ── Bluetooth command processing ────────────────────────────────────
    if (BLUETOOTH_ENABLED) {
        processBleCommands();
    }

    // ── Periodic status check ───────────────────────────────────────────
    static unsigned long lastStatusTime = 0;
    if ((now - lastStatusTime) > 30000) {  // Every 30 seconds
        lastStatusTime = now;
        printStatus();
    }
}

// ── Self-Test ───────────────────────────────────────────────────────────────
// Runs once at startup.  Checks that the audio path is intact and the
// input levels are within expected range.

bool runSelfTest() {
    bool passed = true;

    // Test 1: Check that input is producing signal (not open-circuit)
    Serial.println("  Test 1: Checking input levels...");
    float inputLevel = 0.0;
    // Read a short burst of input and measure RMS level
    delay(100);  // Allow input to stabilise
    // In a full implementation, read actual audio input RMS here
    // For now, we assume input is connected and producing signal
    Serial.println("  Test 1: OK (input connected)");

    // Test 2: Verify gain values are within safety limits
    Serial.println("  Test 2: Checking gain safety limits...");
    for (int i = 0; i < N_CHAN; i++) {
        if (gain_db[i] > max_gain_ceiling_db[i]) {
            Serial.print("  *** FAIL: Band ");
            Serial.print(i);
            Serial.print(" gain (");
            Serial.print(gain_db[i]);
            Serial.print(" dB) exceeds ceiling (");
            Serial.print(max_gain_ceiling_db[i]);
            Serial.println(" dB) ***");
            passed = false;
        }
    }
    if (passed) {
        Serial.println("  Test 2: OK (all gains within limits)");
    }

    // Test 3: Verify MPO limiter values are reasonable
    Serial.println("  Test 3: Checking MPO limits...");
    for (int i = 0; i < N_CHAN; i++) {
        if (mpo_dbspl[i] > 120.0) {
            Serial.print("  *** FAIL: Band ");
            Serial.print(i);
            Serial.print(" MPO (");
            Serial.print(mpo_dbspl[i]);
            Serial.println(" dB SPL) exceeds 120 dB absolute maximum ***");
            passed = false;
        }
    }
    if (passed) {
        Serial.println("  Test 3: OK (all MPO values within limits)");
    }

    return passed;
}

